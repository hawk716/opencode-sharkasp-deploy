# متغيرات البيئة لـ OpenCode Web Interface

# كلمة مرور خادم OpenCode
OPENCODE_SERVER_PASSWORD=admin123

# رابط OpenCode (في الإنتاج، استخدم رابط Vercel)
NEXT_PUBLIC_OPENCODE_URL=http://localhost:8080

# Vercel Blob Storage (يتم إضافتها تلقائياً من قبل Vercel)
# BLOB_READ_WRITE_TOKEN=

# متغيرات Vercel الأخرى (اختيارية)
# VERCEL_URL=
# NODE_ENV=production
