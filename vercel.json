{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "env": {
    "OPENCODE_SERVER_PASSWORD": {
      "description": "Password for OpenCode web interface",
      "default": "admin123",
      "required": false
    }
  },
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x",
      "memory": 1024
    }
  },
  "redirects": [
    {
      "source": "/opencode",
      "destination": "http://localhost:8080",
      "statusCode": 307
    }
  ]
}
